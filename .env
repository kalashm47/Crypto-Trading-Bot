# Binance API Configuration
# Get your API keys from https://www.binance.com/en/support/faq/how-to-create-api-keys-360002502072
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_BASE_URL=

# Trading Configuration
TRADING_SYMBOL=BTC-USD
FETCH_INTERVAL=1m

# Strategy Parameters
SMA_SHORT_WINDOW=10
SMA_LONG_WINDOW=30

# Bot Settings
UPDATE_INTERVAL=60  # seconds between price updates
MAX_HISTORY=100  # number of prices to keep in memory

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
